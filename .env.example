# -----------------------------
# Database (postgres:15 service)
# -----------------------------
# Passed to the db container by docker-compose (POSTGRES_DB/USER/PASSWORD only).
POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=change_me

# Backend connection string (env has higher priority than config.json).
# Compose default host/port: db:5432 — update user, password, and db name to match above.
SQLALCHEMY_DATABASE_URI=postgresql://auth:change_me@db:5432/auth
# Optional alias for SQLALCHEMY_DATABASE_URI (higher priority than config.json too)
# DB_URL=postgresql://auth:change_me@db:5432/auth

# -----------------------------
# Backend runtime
# -----------------------------
BACKEND_PORT=8077
# Apply Alembic migrations on backend container start (default true). Set false when
# running migrations separately (e.g. multiple backend replicas).
RUN_MIGRATIONS=true
# Seed admin user/group on backend start (idempotent; default true).
RUN_INIT_DB=true
GUNICORN_WORKERS=2
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=120
FLASK_DEBUG=false

# -----------------------------
# Frontend runtime/build
# -----------------------------
FRONTEND_PORT=8080
# Must end with "/" when using subpath deployment.
# Use "/" for root deployment, "/id/" for http://example.com/id/
# docker-compose maps FRONTEND_BASE_PATH to VITE_SITE_BASE_URL at build time (app routes/API).
# Docker/nginx builds leave VITE_STATIC_PATH empty. For flask run + local npm run build use VITE_STATIC_PATH=static/
# SITE_* below are also mapped into the frontend build (VITE_SITE_*); rebuild frontend after changes.
# BACKEND_UPSTREAM (backend:<BACKEND_PORT>) is set automatically for nginx; do not set here.
FRONTEND_BASE_PATH=/
# Optional build args (passed through docker-compose frontend build):
# VITE_FORCE_THEME=dark
# VITE_FORCE_LOCALE=zh-Hans
# Local Vite dev only (see frontend/.env.example): VITE_FLASK_ORIGIN, VITE_DEV_API_DELAY_MS

# -----------------------------
# Security and app overrides
# -----------------------------
SECRET_KEY=change_this_secret_key
SITE_NAME=Identity
SITE_ROOT_URL=http://localhost:8080
SITE_BASE_URL=/
SITE_BEHIND_PROXY=true
SITE_ORGANIZATION_NAME=Default Organization
SITE_GROUP_NAME=Default Group
SITE_COPYRIGHT=Copyright © 2026 Example. All rights reserved.

# Admin bootstrap overrides
ADMIN_NAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Mail overrides
# MAIL_ENABLED=false
MAIL_FROM=noreply@example.com
MAIL_DISPLAY_NAME=Identity
# MAIL_REPLY_TO=support@example.com
# MAIL_REPLY_TO_NAME=Support Team

# Outbound SMTP (Docker backend uses msmtp when MAIL_SMTP_HOST is set)
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USER=
# MAIL_SMTP_PASSWORD=
# MAIL_SMTP_TLS=on
# MAIL_SMTP_STARTTLS=on
# MAIL_SMTP_AUTH=on

# Upload override
UPLOAD_ROOT_FOLDER=upload

# CAPTCHA microservice (recaptcha + redis compose services)
CAPTCHA_ENABLED=true
CAPTCHA_SECRET=change_me
CAPTCHA_SERVICE_URL=http://recaptcha:8090
CAPTCHA_TTL_SECONDS=120
CAPTCHA_PORT=8090

# Optional OAuth client bootstrap (single client, imported on backend container start)
# OAUTH_CLIENT_NAME=testapp
# OAUTH_CLIENT_SECRET=integration-test-secret
# OAUTH_CLIENT_REDIRECT_URL=http://localhost:3000/oauth/callback
# OAUTH_CLIENT_HOME_URL=http://localhost:3000
# OAUTH_CLIENT_DESCRIPTION=Integration test OAuth client
# OAUTH_CLIENT_IS_PUBLIC=true

# -----------------------------
# Docker build mirrors/cache
# -----------------------------
APT_MIRROR=mirrors.tuna.tsinghua.edu.cn
ALPINE_MIRROR=mirrors.tuna.tsinghua.edu.cn
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
NPM_REGISTRY=https://registry.npmmirror.com

# Optional local caches for offline-leaning builds
# PIP_CACHE_DIR=./pip_cache

# GeoLite MMDB: run ./scripts/download-mmdb.sh before docker compose build backend

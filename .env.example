# -----------------------------
# Database (postgres:15 service)
# -----------------------------
POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Used by backend app config (env has higher priority than config.json)
SQLALCHEMY_DATABASE_URI=postgresql://auth:change_me@db:5432/auth
# Optional alias for SQLALCHEMY_DATABASE_URI (higher priority than config.json too)
# DB_URL=postgresql://auth:change_me@db:5432/auth

# -----------------------------
# Backend runtime
# -----------------------------
BACKEND_PORT=8077
GUNICORN_WORKERS=2
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=120
FLASK_DEBUG=false

# -----------------------------
# Frontend runtime/build
# -----------------------------
FRONTEND_PORT=8080
# Must end with "/" when using subpath deployment.
# Use "/" for root deployment, "/id/" for http://example.com/id/
FRONTEND_BASE_PATH=/

# -----------------------------
# Security and app overrides
# -----------------------------
SECRET_KEY=change_this_secret_key
SITE_ROOT_URL=http://localhost:8080
SITE_BASE_URL=/
SITE_BEHIND_PROXY=true

# Admin bootstrap overrides
ADMIN_NAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Mail overrides
MAIL_FROM=noreply@example.com
MAIL_DISPLAY_NAME=Identity
# MAIL_REPLY_TO=support@example.com
# MAIL_REPLY_TO_NAME=Support Team

# Upload override
UPLOAD_ROOT_FOLDER=upload

# -----------------------------
# Docker build mirrors/cache
# -----------------------------
APT_MIRROR=mirrors.tuna.tsinghua.edu.cn
ALPINE_MIRROR=mirrors.tuna.tsinghua.edu.cn
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
NPM_REGISTRY=https://registry.npmmirror.com

# Optional local caches for offline-leaning builds
# PIP_CACHE_DIR=./pip_cache

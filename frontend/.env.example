# Flask dev server origin for Vite proxy (browser stays on Vite; /api, /oauth, /upload forwarded here)
VITE_FLASK_ORIGIN=http://127.0.0.1:8077

# Must match SITE.base_url in the backend config.json (e.g. "/" or "/app/"). Used for relative upload paths (avatars, OAuth icons).
VITE_SITE_BASE_URL=/

# Optional site branding overrides (take precedence over config.json SITE.*).
# Root .env SITE_* vars are also picked up when running Vite from frontend/ (see vite.config.ts).
# VITE_SITE_NAME=Identity
# VITE_SITE_ORGANIZATION_NAME=Default Organization
# VITE_SITE_GROUP_NAME=Default Group
# VITE_SITE_COPYRIGHT=Copyright © 2026 Example. All rights reserved.

# Dev only: artificial delay (ms) after each /api response so you can tune loading and error UI.
# VITE_DEV_API_DELAY_MS=800

# Optional: lock UI to light or dark (hides theme switch). Overrides config.json UI.force_theme.
# VITE_FORCE_THEME=dark

# Optional: lock UI to en or zh-Hans (hides language switch). Overrides config.json UI.force_locale.
# VITE_FORCE_LOCALE=zh-Hans

# Optional: disable outbound email UI (registration, send-email nav, etc.). Overrides config.json MAIL.enabled.
# Root .env MAIL_ENABLED is also mapped when running Vite from frontend/ (see vite.config.ts).
# VITE_MAIL_ENABLED=false
